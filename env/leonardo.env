# Leonardo cluster environment for post-training container workflows

# Hugging Face cache and offline settings
export HF_HOME=/leonardo_scratch/large/userexternal/knikolao/huggingface
export HF_HUB_CACHE=$HF_HOME/hub
export HUGGINGFACE_HUB_CACHE=$HF_HOME/hub
export HF_DATASETS_CACHE=$HF_HOME/datasets
export TRANSFORMERS_CACHE=$HF_HOME
export HF_DATASETS_OFFLINE=1
export TRANSFORMERS_OFFLINE=1
export HF_HUB_OFFLINE=1

# Use local post_training source (overrides container's baked-in copy)
export PYTHONPATH=/leonardo_scratch/large/userexternal/knikolao/post_trainig_olmo_trl/post-training/src:${PYTHONPATH:-}

export SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
export GPUS_PER_NODE=4

# NCCL: prefix-match all Mellanox IB HCAs so multi-HCA compute nodes use both
# rails instead of NCCL's auto-pick of the first one only.
# Verified against CINECA / EuroHPC best-practice docs:
#   https://eurohpcsupport.eu/best-practice/best-practice-guide-to-running-ai-workloads-on-leonardo-cineca/
export NCCL_IB_HCA=mlx5

# WandB
export WANDB_API_KEY=<your-wandb-api-key>
export WANDB_MODE=offline
export WANDB_ENTITY=openeurollm-project
export WANDB_PROJECT=propella-olmo-sft
